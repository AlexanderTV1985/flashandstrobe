<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Общие -->
    <color name="background_dark">#121212</color>   <!-- Тёмный фон экрана -->
    <color name="text_primary">#FFFFFF</color>       <!-- Основной белый текст -->
    <color name="text_hint">#AAAAAA</color>          <!-- Вспомогательный серый текст -->


    <!-- Фонарик -->
    <color name="flash_on">#FF5722</color>        <!-- Оранжево‑красный: фонарик включён -->
    <color name="flash_off">#FFC107</color>      <!-- Жёлтый: кнопка в режиме «выключено» -->
    <!-- Новый цвет: тёмный оттенок для эффекта пульсации кнопки в такт вспышке -->
    <color name="flash_btn_dim">#6A3501</color>


        <!-- Стробоскоп -->
    <color name="strobe_btn">#FFEB3B</color>         <!-- Яркий жёлтый (когда вспышка горит) -->
    <color name="strobe_text">#000000</color>      <!-- Чёрный текст -->
    <color name="strobe_btn_dim">#6A6C01</color>     <!-- Чуть приглушённый жёлтый (когда вспышка гаснет) -->


    <!-- SOS -->
    <color name="sos_btn">#FF000D</color>            <!-- Красный для кнопки SOS -->
    <color name="sos_text">#FFFFFF</color>          <!-- Белый текст на кнопке SOS -->
    <!-- Новый цвет: тёмный оттенок для эффекта пульсации кнопки в такт вспышке -->
    <color name="sos_btn_dim">#4B0005</color>

    <!-- Flicker («Космический шум») -->
    <color name="flicker_btn">#8BC34A</color>        <!-- Мягкий зелёный — ассоциация с «помехами/экраном» -->
    <color name="flicker_text">#000000</color>      <!-- Чёрный текст для контраста на зелёном -->
    <!-- Новый цвет: тёмный оттенок для пульсации в такт мерцанию -->
    <color name="flicker_btn_dim">#3A4F1A</color>

    <!-- About -->
    <color name="about_btn">#444444</color>         <!-- Тёмно‑серый для кнопки About (как в макете) -->
    <color name="about_text">@color/text_primary</color>

    <!-- Цвета для AboutActivity -->
    <color name="about_bg">@color/background_dark</color>
    <color name="about_title">@color/text_primary</color>
    <color name="about_body">@color/text_primary</color>
    <color name="about_muted">@color/text_hint</color>
</resources>
