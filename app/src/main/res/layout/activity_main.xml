<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineCenter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.28" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnFlashlight"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:minHeight="?attr/actionBarSize"
        android:backgroundTint="@color/flash_on"
        android:text="@string/btn_flashlight"
        android:textColor="@color/text_primary"
        app:cornerRadius="12dp"
        app:layout_constraintTop_toTopOf="@+id/guidelineCenter"
        app:layout_constraintBottom_toTopOf="@id/btnStrobe"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStrobe"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:minHeight="?attr/actionBarSize"
        android:text="@string/btn_strobe"
        android:backgroundTint="@color/strobe_btn"
        android:textColor="@color/strobe_text"
        android:layout_marginTop="16dp"
        app:cornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@id/btnFlashlight"
        app:layout_constraintBottom_toTopOf="@id/btnSos"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSos"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:minHeight="?attr/actionBarSize"
        android:text="@string/btn_sos"
        android:backgroundTint="@color/sos_btn"
        android:textColor="@color/sos_text"
        android:layout_marginTop="16dp"
        app:cornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@id/btnStrobe"
        app:layout_constraintBottom_toTopOf="@id/btnFlicker"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnFlicker"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:minHeight="?attr/actionBarSize"
        android:text="@string/btn_flicker"
        android:backgroundTint="@color/flicker_btn"
        android:textColor="@color/flicker_text"
        android:layout_marginTop="16dp"
        app:cornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@id/btnSos"
        app:layout_constraintBottom_toTopOf="@id/btnAbout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAbout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="0dp"
        android:minHeight="?attr/actionBarSize"
        android:text="@string/btn_about"
        android:backgroundTint="#444444"
        android:textColor="@color/text_primary"
        android:layout_marginTop="32dp"
        app:cornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@id/btnFlicker"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
