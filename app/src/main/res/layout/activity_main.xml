<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="@color/background_dark">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineCenter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.2" />

    <!-- Кнопка Flashlight -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnFlashlight"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:minHeight="?attr/actionBarSize"
        android:backgroundTint="@color/flash_on"
        android:textSize="26sp"
        android:textStyle="bold"
        android:text="@string/btn_flashlight"
        android:textColor="@color/text_primary"
        app:layout_constraintWidth_percent="0.8"
        app:cornerRadius="12dp"
        app:elevation="4dp"
        app:rippleColor="#80FFFFFF"
        app:layout_constraintTop_toTopOf="@+id/guidelineCenter"
        app:layout_constraintBottom_toTopOf="@id/space1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Отступ 16dp -->
    <Space
        android:id="@+id/space1"
        android:layout_width="wrap_content"
        android:layout_height="16dp"
        app:layout_constraintTop_toBottomOf="@id/btnFlashlight"
        app:layout_constraintBottom_toTopOf="@id/btnStrobe"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Кнопка Strobe -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStrobe"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:minHeight="?attr/actionBarSize"
        android:text="@string/btn_strobe"
        android:backgroundTint="@color/strobe_btn"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="@color/strobe_text"
        app:layout_constraintWidth_percent="0.8"
        app:cornerRadius="12dp"
        app:elevation="4dp"
        app:rippleColor="#80FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/space1"
        app:layout_constraintBottom_toTopOf="@id/space2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Отступ 16dp -->
    <Space
        android:id="@+id/space2"
        android:layout_width="wrap_content"
        android:layout_height="16dp"
        app:layout_constraintTop_toBottomOf="@id/btnStrobe"
        app:layout_constraintBottom_toTopOf="@id/btnSos"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Кнопка SOS -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSos"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:minHeight="?attr/actionBarSize"
        android:text="@string/btn_sos"
        android:backgroundTint="@color/sos_btn"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="@color/sos_text"
        app:layout_constraintWidth_percent="0.8"
        app:cornerRadius="12dp"
        app:elevation="4dp"
        app:rippleColor="#80FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/space2"
        app:layout_constraintBottom_toTopOf="@id/space3"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Отступ 16dp -->
    <Space
        android:id="@+id/space3"
        android:layout_width="wrap_content"
        android:layout_height="16dp"
        app:layout_constraintTop_toBottomOf="@id/btnSos"
        app:layout_constraintBottom_toTopOf="@id/btnFlicker"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Кнопка Flicker -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnFlicker"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:minHeight="?attr/actionBarSize"
        android:text="@string/btn_flicker"
        android:backgroundTint="@color/flicker_btn"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="@color/flicker_text"
        app:layout_constraintWidth_percent="0.8"
        app:cornerRadius="12dp"
        app:elevation="4dp"
        app:rippleColor="#80FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/space3"
        app:layout_constraintBottom_toTopOf="@id/space4"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Отступ 16dp -->
    <Space
        android:id="@+id/space4"
        android:layout_width="wrap_content"
        android:layout_height="16dp"
        app:layout_constraintTop_toBottomOf="@id/btnFlicker"
        app:layout_constraintBottom_toTopOf="@id/btnAbout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Кнопка About -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAbout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:minHeight="?attr/actionBarSize"
        android:text="@string/btn_about"
        android:backgroundTint="@color/about_btn"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/about_text"
        app:layout_constraintWidth_percent="0.5"
        app:cornerRadius="12dp"
        app:elevation="4dp"
        app:rippleColor="#80FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/space4"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Статус сборки (Beta) -->
    <TextView
        android:id="@+id/tvBuildStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/about_build_status"
        android:textColor="#AAFFFFFF"
        android:textSize="12sp"
        android:gravity="center"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnAbout"
        android:layout_marginTop="24dp"/>
</androidx.constraintlayout.widget.ConstraintLayout>
