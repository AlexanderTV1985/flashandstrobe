<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <Button
        android:id="@+id/btnFlashlight"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/btn_flashlight"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="spread" />

    <Button
        android:id="@+id/btnStrobe"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/btn_strobe"
        app:layout_constraintTop_toBottomOf="@id/btnFlashlight"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnSos"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/btn_sos"
        app:layout_constraintTop_toBottomOf="@id/btnStrobe"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnFlicker"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/btn_flicker"
        app:layout_constraintTop_toBottomOf="@id/btnSos"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Кнопка «О приложении» -->
    <Button
        android:id="@+id/btnAbout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/btn_about"
        android:minWidth="0dp"
        app:layout_constraintTop_toBottomOf="@id/btnFlicker"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp"/>
</androidx.constraintlayout.widget.ConstraintLayout>
