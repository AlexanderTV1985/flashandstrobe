<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <TextView
        android:id="@+id/tvStatusStrobe"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Готов к работе"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btnToggleStrobe"
        android:layout_width="0dp"
        android:layout_height="120dp"
        android:text="ВКЛЮЧИТЬ СТРОБОСКОП"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/strobe_text"
        android:backgroundTint="@color/strobe_btn"
        app:layout_constraintTop_toBottomOf="@id/tvStatusStrobe"
        app:layout_constraintBottom_toTopOf="@id/seekFrequency"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_percent="0.8"/>

    <SeekBar
        android:id="@+id/seekFrequency"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:max="20"
        android:progress="10"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/btnToggleStrobe"
        app:layout_constraintBottom_toTopOf="@id/tvFreqValue"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_percent="0.8"/>

    <TextView
        android:id="@+id/tvFreqValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Частота: 10 Гц"
        android:textColor="@color/text_hint"
        android:textSize="14sp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/seekFrequency"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
