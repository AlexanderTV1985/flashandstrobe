<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <!-- Статус: теперь с отступом от верха, чтобы не наезжать на вырез камеры -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:text="@string/tv_status_ready"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        android:gravity="center"
        android:ellipsize="end"
        android:maxLines="3"

        android:layout_marginTop="48dp"

    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintWidth_percent="0.8" />

    <!-- Кнопка: якорь примерно по центру экрана -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnToggleStrobe"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:minHeight="64dp"
        android:maxHeight="120dp"
        android:paddingVertical="12dp"
        android:text="@string/btn_strobe"
        android:backgroundTint="@color/strobe_btn"
        android:textColor="@color/strobe_text"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textAllCaps="false"
        app:cornerRadius="16dp"
        app:elevation="4dp"
        app:rippleColor="#80FFFFFF"

        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintVertical_bias="0.45"

    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintWidth_percent="0.8" />

    <!-- Подсказка: сразу под кнопкой -->
    <TextView
        android:id="@+id/tvHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/tv_hint_strobe"
        android:textColor="@color/text_hint"
        android:textSize="14sp"
        android:lineHeight="20sp"
        android:layout_marginTop="24dp"
        android:gravity="center_horizontal"
        app:layout_constraintTop_toBottomOf="@id/btnToggleStrobe"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Ползунок: сразу под подсказкой -->
    <SeekBar
        android:id="@+id/seekFrequency"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/tvHint"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_percent="0.8"
        android:layout_marginTop="24dp" />

    <!-- Значение частоты: под ползунком -->
    <TextView
        android:id="@+id/tvFreqValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="3 Гц"
        android:textColor="@color/text_hint"
        android:textSize="14sp"
        android:lineHeight="20sp"
        app:layout_constraintTop_toBottomOf="@id/seekFrequency"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp" />
</androidx.constraintlayout.widget.ConstraintLayout>
