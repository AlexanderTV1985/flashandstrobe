<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="16dp"
        android:text="@string/tv_status_ready"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        android:gravity="center"
        android:ellipsize="end"
        android:maxLines="3"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnToggleSos"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_percent="0.8"
        app:layout_constraintHeight_percent="0.22" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnToggleSos"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:minHeight="48dp"
        android:backgroundTint="@color/sos_btn"
        android:text="@string/btn_sos"
        android:textColor="@color/sos_text"
        android:textSize="18sp"
        android:textStyle="bold"
        app:cornerRadius="16dp"
        app:elevation="4dp"
        app:rippleColor="#80FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/tvStatus"
        app:layout_constraintBottom_toTopOf="@id/tvHint"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_percent="0.8"
        app:layout_constraintVertical_bias="0.5" />

    <TextView
        android:id="@+id/tvHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/tv_hint_sos"
        android:textColor="@color/text_hint"
        android:textSize="14sp"
        android:lineHeight="20sp"
        app:layout_constraintTop_toBottomOf="@id/btnToggleSos"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />
</androidx.constraintlayout.widget.ConstraintLayout>
